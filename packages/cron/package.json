{
    "name": "@breezeapi/cron",
    "version": "1.1.1",
    "main": "index.ts",
    "types": "index.ts",
    "description": "Breeze plugin for cron jobs.",
    "keywords": [
        "breeze",
        "cron",
        "plugin"
    ],
    "license": "MIT",
    "scripts": {
        "build": "bun build index.ts --outdir ./out --target bun",
        "types": "tsc --emitDeclarationOnly --declaration --outDir ./out",
        "build:all": "bun run build && bun run types",
        "release": "npm version patch && bun run build:all && bun publish"
    },
    "dependencies": {
        "cron": "^2.4.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0"
    }
}
